<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="openssl-native" Version="3.5.5" GeneratePathProperty="true" ExcludeAssets="all" PrivateAssets="all" />
    <PackageReference Include="SharpCompress" Version="0.49.1" />
  </ItemGroup>
  <ItemGroup>
    <None Include="$(Pkgopenssl-native)\include\**\*" Link="tools\openssl\win-x64\include\%(RecursiveDir)%(FileName)%(Extension)" CopyToOutputDirectory="PreserveNewest" />
    <None Include="$(Pkgopenssl-native)\include\**\*" Link="tools\openssl\win-arm64\include\%(RecursiveDir)%(FileName)%(Extension)" CopyToOutputDirectory="PreserveNewest" />
    <None Include="$(Pkgopenssl-native)\lib\win-x64\native\*.lib" Link="tools\openssl\win-x64\lib\%(FileName)%(Extension)" CopyToOutputDirectory="PreserveNewest" />
    <None Include="$(Pkgopenssl-native)\runtimes\win-x64\native\*.dll" Link="tools\openssl\win-x64\bin\%(FileName)%(Extension)" CopyToOutputDirectory="PreserveNewest" />
    <None Include="$(Pkgopenssl-native)\lib\win-arm64\native\*.lib" Link="tools\openssl\win-arm64\lib\%(FileName)%(Extension)" CopyToOutputDirectory="PreserveNewest" />
    <None Include="$(Pkgopenssl-native)\runtimes\win-arm64\native\*.dll" Link="tools\openssl\win-arm64\bin\%(FileName)%(Extension)" CopyToOutputDirectory="PreserveNewest" />
    <None Include="$(Pkgopenssl-native)\docs\license.txt" Link="tools\openssl\license.txt" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
